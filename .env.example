# ─────────────────────────────────────────────────────────
#  RAQABA v7 — Environment Variables
#  Copy this file to .env and fill in your values
#  Never commit .env to Git
# ─────────────────────────────────────────────────────────

# REQUIRED
RAQABA_SECRET=put-a-long-random-string-here-at-least-32-chars

# Database path (SQLite file)
RAQABA_DB=raqaba.db

# Video source
# Use a file path for recorded video, or 0 for webcam
RAQABA_VIDEO=videos/demo.mp4

# ─── Twilio (optional) ────────────────────────────────────
# Sign up at https://www.twilio.com — free trial available
# For WhatsApp: use "whatsapp:+14155238886" as TWILIO_FROM
# For SMS:      use your Twilio phone number "+1xxxxxxxxxx"

# TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TOKEN=your_auth_token_here
# TWILIO_FROM=whatsapp:+14155238886
